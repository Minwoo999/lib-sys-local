<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context" xmlns:jdbc="http://www.springframework.org/schema/jdbc" xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-4.0.xsd
        http://www.springframework.org/schema/jdbc http://www.springframework.org/schema/jdbc/spring-jdbc-4.0.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-4.0.xsd">


    <!-- Oracle production config (disabled by default) -->
    <!-- <bean id="dataSource" class="org.apache.commons.dbcp2.BasicDataSource" destroy-method="close">
        <property name="driverClassName" value="oracle.jdbc.driver.OracleDriver"/>
        <property name="url" value="jdbc:oracle:thin:@127.0.0.1:1521:example" />
        <property name="username" value="minwoo"/>
        <property name="password" value="1234"/>
    </bean> -->

    <context:property-placeholder location="classpath:props/database.properties" />

    <!-- DataSource with auto-initialization from schema.sql (HSQLDB) -->
    <bean id="dataSource" class="org.apache.commons.dbcp2.BasicDataSource" destroy-method="close">
        <property name="driverClassName" value="${oracle.driver.className}"/>
        <property name="url" value="${oracle.url}" />
        <property name="username" value="${oracle.username}"/>
        <property name="password" value="${oracle.password}"/>
        <!-- HSQLDB auto-init: run schema.sql on startup -->
        <property name="connectionInitSqls">
            <list>
                <value></value>
            </list>
        </property>
    </bean>

    <!-- Schema initializer for HSQLDB (runs schema.sql once) -->
    <bean class="org.springframework.jdbc.datasource.init.DataSourceInitializer">
        <property name="dataSource" ref="dataSource"/>
        <property name="schemaLocations">
            <list>
                <value>classpath:schema.sql</value>
            </list>
        </property>
        <property name="enabled" value="true"/>
    </bean>

</beans>
